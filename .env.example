# ===========================================
# SOVEREIGN COUNCIL - API KEYS
# ===========================================
# Get free keys from each provider's developer portal

# ===== PRIMARY ORCHESTRATOR =====
# Google AI Studio (Gemini 4 Flash) - PRIMARY - https://aistudio.google.com/app/apikey
# 1500 requests/day free - Best overall performance
GEMINI_API_KEY=

# ===== FREE FALLBACKS (when primary exhausted) =====
# OpenRouter - Aggregates 30+ free models - https://openrouter.ai/keys
# Free models include: Gemma 3 4B, Liquid LFM 2.5, Qwen, DeepSeek, Llama, etc.
OPENROUTER_API_KEY=

# ===== ADDITIONAL AI PROVIDERS =====
# Groq (Fastest Llama inference) - https://console.groq.com/keys
GROQ_API_KEY=

# Mistral AI - https://console.mistral.ai/api-keys/
MISTRAL_API_KEY=

# HuggingFace Inference - https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=

# Together AI - https://api.together.ai/settings/api-keys
TOGETHER_API_KEY=

# NVIDIA NIM (Nemotron) - https://build.nvidia.com/settings/api-keys
NVIDIA_API_KEY=

# ===== SEARCH PROVIDERS =====
# Tavily (AI Search) - https://app.tavily.com/
TAVILY_API_KEY=

# Serper (Google) - https://serper.dev/api-key
SERPER_API_KEY=

# ===== SERVER =====
PORT=3000
BETTER_AUTH_URL=http://localhost:3000